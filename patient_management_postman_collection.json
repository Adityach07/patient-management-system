						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"Saved token from registration: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser121@example.com\",\n  \"password\": \"securepassword123121\",\n  \"role\": \"ROLE_USER\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
